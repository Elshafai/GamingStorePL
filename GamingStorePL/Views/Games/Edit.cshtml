@model EditGameVM

@{
    ViewData["Title"] = "Edit Game";
}

<h4>
    <i class="bi bi-pencil-square"></i> Edit Game
</h4>

<form asp-action="Edit" asp-controller="Games" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CurrentCover" />

    <div class="row">
        <div class="col-md-6">
            <div>
                <label asp-for="Name" class="form-label mt-4"></label>
                <input type="text" class="form-control" asp-for="Name" placeholder="Enter Name">
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Quantity" class="form-label mt-4"></label>
                <input type="text" class="form-control" asp-for="Quantity" placeholder="Enter Quantity">
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Price" class="form-label mt-4"></label>
                <input type="text" class="form-control" asp-for="Price" placeholder="Enter Price">
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="CategoryId" class="form-label mt-4"></label>
                <select class="form-select" asp-for="CategoryId" asp-items="Model.Categories"
                        data-placeholder="Select a Category"
                        data-minimum-results-for-search="Infinity">
                    <option value=""></option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="SelectedDevices" class="form-label mt-4"></label>
                <select class="form-select" asp-for="SelectedDevices" asp-items="Model.Devices"
                        data-placeholder="Select Devices" multiple>
                </select>
                <span asp-validation-for="SelectedDevices" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Description" class="form-label mt-4"></label>
                <textarea asp-for="Description" class="form-control"
                          placeholder="Enter Description"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="CoverImage" class="form-label mt-4">Cover Image</label>
                <input type="file" class="form-control" asp-for="CoverImage"
                       data-rule-extension="@FileSettings.AllowedExtensions.Replace(".", string.Empty)"
                       data-msg-extension="Only @FileSettings.AllowedExtensions files are allowed"
                       data-rule-filesize="@FileSettings.MaxFileSizeInMB"
                       data-msg-filesize="Max size @FileSettings.MaxFileSizeInMB MB" />
                <small class="form-text text-muted">
                    Leave empty to keep current cover.
                    Only @FileSettings.AllowedExtensions — max @FileSettings.MaxFileSizeInMB MB
                </small>
                <span asp-validation-for="CoverImage" class="text-danger d-block"></span>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary text-white">
                    <i class="bi bi-save"></i> Save
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </div>

        <div class="col-md-6 d-flex justify-content-center pt-4 overflow-hidden">
            @if (!string.IsNullOrEmpty(Model.CurrentCover))
            {
                <img src="~/Files/@Model.CurrentCover"
                     class="CoverImage-preview img-fluid rounded shadow"
                     style="max-height: 350px; object-fit: cover;"
                     alt="Current Cover" />
            }
            else
            {
                <img class="CoverImage-preview d-none" alt="CoverImage" />
            }
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/filessize.js" asp-append-version="true"></script>
    <script src="~/js/gamecover.js" asp-append-version="true"></script>
}