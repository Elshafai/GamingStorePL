@model IEnumerable<GameVM>

@{
    ViewData["Title"] = "Games";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-controller"></i> Games</h4>
    <a class="btn btn-outline-primary" asp-action="Create">
        <i class="bi bi-plus"></i> Add New Game
    </a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var game in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <img src="~/Files/@game.Cover" class="card-img-top"
                     style="height:auto; object-fit:cover;"
                     onerror="this.src='/images/placeholder.png'" />
                <div class="card-body">
                    <h5 class="card-title">@game.Name</h5>
                    <p class="card-text text-muted small">
                        @(game.Description.Length > 100
                                            ? game.Description[..100] + "..."
                                            : game.Description)
                </p>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item">
                    <i class="bi bi-tag"></i> @game.Category
                </li>
                <li class="list-group-item">
                    <i class="bi bi-currency-dollar"></i> @game.Price.ToString("F2")
                </li>
                <li class="list-group-item">
                    <i class="bi bi-box-seam"></i> Qty: @game.Quantity
                </li>
                <li class="list-group-item">
                    <i class="bi bi-display"></i>
                    @string.Join(", ", game.Devices)
                </li>
            </ul>
            <div class="card-footer">
                <a asp-action="Details" asp-route-id="@game.Id"
                   class="btn btn-sm btn-outline-primary w-100">
                    <i class="bi bi-eye"></i> Details
                </a>
            </div>
        </div>
    </div>
        }
</div>